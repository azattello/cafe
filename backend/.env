# ========================================
# СЕРВЕРНАЯ КОНФИГУРАЦИЯ
# ========================================
# Порт на котором запускается сервер
PORT=5000

# Окружение (development/production)
NODE_ENV=development

# ========================================
# DATABASE - MONGODB ATLAS
# ========================================
# Облачная база данных MongoDB Atlas
MONGODB_URI=mongodb+srv://azatabdykalli_db_user:H8DL1baPVWTMhALJ@cluster0.1h2bufe.mongodb.net/?appName=Cluster0

# Локальная MongoDB (для разработки, если нужна)
# MONGODB_LOCAL=mongodb://127.0.0.1:27017/cafe_db

# ========================================
# АУТЕНТИФИКАЦИЯ И БЕЗОПАСНОСТЬ
# ========================================
# Секретный ключ для подписи JWT токенов
JWT_SECRET=cafe_management_system_super_secret_key_2026_production

# Время действия JWT токена (в часах)
JWT_EXPIRY=24h

# ========================================
# CORS И ДОСТУП
# ========================================
# Разрешенные источники для CORS
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ========================================
# ОПЦИОНАЛЬНЫЕ СЕРВИСЫ
# ========================================
# Cloudinary для загрузки изображений (если будет реализовано)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Email сервис для отправки уведомлений (если будет реализовано)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# ========================================
# ЛОГИРОВАНИЕ И ОТЛАДКА
# ========================================
# Включить детальное логирование
DEBUG=false

# Файл для логов
LOG_FILE=./logs/server.log
